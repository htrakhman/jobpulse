generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ApplicationStage {
  Applied
  Waiting
  Scheduling
  Interviewing
  Assessment
  Offer
  Rejected
  Closed
}

enum EmailType {
  application_confirmation
  interview_request
  interview_scheduled
  assessment
  rejection
  offer
  general_update
  unknown
}

enum ApplicationSource {
  linkedin
  company_site
  referral
  recruiter_outreach
  yc
  indeed
  wellfound
  glassdoor
  other
  unknown
}

enum ApplicationMethod {
  cold_apply
  referral
  warm_intro
  recruiter_inbound
  direct_outreach
  other
  unknown
}

enum TargetPriority {
  dream
  high
  medium
  low
}

enum FollowUpUrgency {
  urgent
  high
  normal
  low
}

enum OfferOutcome {
  pending
  accepted
  declined
}

enum OutcomeReason {
  lack_of_experience
  role_mismatch
  technical_gap
  unclear_communication
  comp_mismatch
  internal_candidate
  hiring_freeze
  unknown
}

enum WorkModelPreference {
  remote
  hybrid
  onsite
}

model User {
  id               String            @id // Clerk user ID
  email            String            @unique
  createdAt        DateTime          @default(now())
  gmailAccessRequestedAt DateTime?
  initialScanStartedAt   DateTime?
  initialScanCompletedAt DateTime?
  initialScanRangeDays   Int?
  /// Last successful full/window inbox sync (manual refresh or OAuth connect initial scan).
  lastInboxSyncedAt      DateTime?
  connectedAccount ConnectedAccount?
  applications     Application[]
  contacts         ApplicationContact[]
  followUps        FollowUpSuggestion[]
  goals            UserGoal[]
  goalSnapshots    GoalSnapshot[]
  interviewReviews InterviewReview[]
  savedSearches    SavedSearch[]
  searchRuns       SearchRun[]
}

model ConnectedAccount {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email           String
  accessToken     String   @db.Text
  refreshToken    String   @db.Text
  tokenExpiry     DateTime?
  watchExpiry     DateTime?
  historyId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EmailMessage {
  id              String      @id // Gmail message ID
  threadId        String
  userId          String
  subject         String?
  fromName        String?
  fromEmail       String?
  snippet         String?     @db.Text
  bodyText        String?     @db.Text
  emailType       EmailType   @default(unknown)
  receivedAt      DateTime
  processedAt     DateTime    @default(now())
  applicationId   String?
  application     Application? @relation(fields: [applicationId], references: [id])
  events          ApplicationEvent[]
  contactEvidence ContactEvidence[]

  @@index([userId])
  @@index([threadId])
  @@index([applicationId])
}

model Application {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         String
  role            String?
  source          ApplicationSource @default(unknown)
  method          ApplicationMethod @default(unknown)
  resumeVersion   String?
  coverLetterVersion String?
  targetPriority  TargetPriority    @default(medium)
  salaryBand      String?
  targetCompMin   Int?
  targetCompMax   Int?
  roleDesirabilityScore Int?
  companyDesirabilityScore Int?
  fitScore        Int?
  locationPreferenceFit Int?
  workModelPreference WorkModelPreference?
  outreachSent    Boolean           @default(false)
  contactedRecruiter Boolean        @default(false)
  nextAction      String?
  nextActionDate  DateTime?
  followUpUrgency FollowUpUrgency?
  daysSinceLastTouch Int?
  stageEnteredAt  DateTime?
  lastRespondedAt DateTime?
  offerOutcome    OfferOutcome?
  closedReason    OutcomeReason?
  stage           ApplicationStage @default(Applied)
  appliedAt       DateTime?
  lastActivityAt  DateTime         @default(now())
  threadIds       String[]
  atsProvider     String?
  recruiter       RecruiterContact?
  emails          EmailMessage[]
  events          ApplicationEvent[]
  transitions     ApplicationTransition[]
  activities      ApplicationActivity[]
  interviewReviews InterviewReview[]
  followUps       FollowUpSuggestion[]
  contacts        ApplicationContact[]
  enrichedContacts EnrichedContact[]
  outreachMessages OutreachMessage[]
  savedSearches    SavedSearch[]
  searchRuns       SearchRun[]
  agentRuns        AgentRun[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([userId, stage])
  @@index([userId, company])
  @@index([userId, source])
  @@index([userId, method])
  @@index([userId, targetPriority])
  @@index([nextActionDate])
}

model SavedSearch {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId  String?
  application    Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  name           String
  filterPayload  Json
  sortMode       String?
  maxResults     Int          @default(25)
  pageSize       Int          @default(25)
  lastRunAt      DateTime?
  lastResultCount Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  runs           SearchRun[]

  @@index([userId, createdAt])
  @@index([applicationId])
}

model SearchRun {
  id              String       @id @default(cuid())
  savedSearchId   String?
  savedSearch     SavedSearch? @relation(fields: [savedSearchId], references: [id], onDelete: SetNull)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId   String?
  application     Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  filterPayload   Json
  sortMode        String?
  page            Int          @default(1)
  pageSize        Int          @default(25)
  resultCount     Int          @default(0)
  totalCount      Int          @default(0)
  durationMs      Int?
  providerSummary Json?
  createdAt       DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([savedSearchId])
  @@index([applicationId])
}

model ApplicationContact {
  id             String               @id @default(cuid())
  applicationId  String
  application    Application          @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyDomain  String?
  primaryEmail   String?
  fullName       String?
  inferredTitle  String?
  webProfileUrl  String?
  confidence     Float                @default(0)
  lastResolvedAt DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  emails         ApplicationContactEmail[]
  evidence       ContactEvidence[]

  @@index([applicationId])
  @@index([userId, applicationId])
  @@index([primaryEmail])
  @@index([companyDomain])
}

model ApplicationContactEmail {
  id        String           @id @default(cuid())
  contactId String
  contact   ApplicationContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  email     String
  emailType ContactEmailType @default(unknown)
  source    String?
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([contactId, email])
  @@index([email])
}

model ContactEvidence {
  id             String             @id @default(cuid())
  contactId      String
  contact        ApplicationContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  emailMessageId String?
  emailMessage   EmailMessage?      @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)
  threadId       String?
  sourceEmail    String?
  snippet        String?
  extractedTitle String?
  confidence     Float              @default(0)
  createdAt      DateTime           @default(now())

  @@index([contactId])
  @@index([emailMessageId])
  @@index([threadId])
}

model ApplicationEvent {
  id            String           @id @default(cuid())
  applicationId String
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  emailId       String?
  email         EmailMessage?    @relation(fields: [emailId], references: [id])
  stage         ApplicationStage
  emailType     EmailType
  summary       String?
  occurredAt    DateTime
  createdAt     DateTime         @default(now())

  @@index([applicationId])
}

model RecruiterContact {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name          String?
  email         String?
  lastSeenAt    DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model FollowUpSuggestion {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reason        String
  dueAt         DateTime
  urgency       FollowUpUrgency?
  recommendedAction String?
  recommendationReason String?
  daysSinceLastTouch Int?
  nextStepDate  DateTime?
  generatedBy   String?
  dismissed     Boolean     @default(false)
  dismissedAt   DateTime?
  completed     Boolean     @default(false)
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, dismissed, completed])
  @@index([applicationId])
  @@index([urgency, dueAt])
}

model ApplicationTransition {
  id              String           @id @default(cuid())
  applicationId   String
  application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStage       ApplicationStage?
  toStage         ApplicationStage
  triggerType     String?
  triggerEmailId  String?
  transitionedAt  DateTime
  createdAt       DateTime         @default(now())

  @@index([applicationId, transitionedAt])
  @@index([toStage, transitionedAt])
}

model ApplicationActivity {
  id             String      @id @default(cuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  kind           String
  summary        String?
  occurredAt     DateTime
  metadata       Json?
  createdAt      DateTime    @default(now())

  @@index([applicationId, occurredAt])
}

model InterviewReview {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  applicationId    String
  application      Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewType    String?
  roundNumber      Int?
  confidenceRating Int?
  performanceRating Int?
  roleFitRating    Int?
  interviewerVibe  Int?
  difficulty       Int?
  notes            String?      @db.Text
  outcomeReason    OutcomeReason?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([userId, createdAt])
  @@index([applicationId])
}

model UserGoal {
  id                     String   @id @default(cuid())
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyApplicationGoal   Int      @default(5)
  weeklyApplicationGoal  Int      @default(25)
  weeklyInterviewGoal    Int      @default(3)
  weeklyNetworkingGoal   Int      @default(5)
  weeklyFollowupGoal     Int      @default(10)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId, isActive])
}

model GoalSnapshot {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  windowStart        DateTime
  windowEnd          DateTime
  applicationsCount  Int      @default(0)
  interviewsCount    Int      @default(0)
  networkingCount    Int      @default(0)
  followupCount      Int      @default(0)
  createdAt          DateTime @default(now())

  @@index([userId, windowStart, windowEnd])
}

// ─── Enrichment & Outreach ────────────────────────────────────────────────────

enum EnrichmentStatus {
  pending
  enriched
  partial
  not_found
  error
}

enum OutreachChannel {
  email
  linkedin
}

enum OutreachStatus {
  draft
  sent
  replied
  bounced
  failed
}

enum EnrichmentProvider {
  apollo
  hunter
  pdl
  proxycurl
  lusha
  contactout
  fullenrich
  snovio
  zerobounce
  mixrank
  icypeas
  leadmagic
}

enum ContactEmailType {
  primary
  work
  alias
  personal
  unknown
}

model EnrichedContact {
  id                String            @id @default(cuid())
  applicationId     String
  application       Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId            String

  // Identity
  firstName         String?
  lastName          String?
  fullName          String?
  title             String?
  department        String?
  seniority         String?

  // Contact info
  email             String?
  emailVerified     Boolean           @default(false)
  emailSource       EnrichmentProvider?
  linkedinUrl       String?
  linkedinSource    EnrichmentProvider?
  twitterHandle     String?
  phone             String?

  // Company context
  company           String
  companyDomain     String?
  companyLinkedinUrl String?

  enrichmentStatus  EnrichmentStatus  @default(pending)
  enrichedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  attempts          EnrichmentAttempt[]
  messages          OutreachMessage[]

  @@index([applicationId])
  @@index([userId])
  @@index([email])
}

model EnrichmentAttempt {
  id           String             @id @default(cuid())
  contactId    String
  contact      EnrichedContact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  provider     EnrichmentProvider
  field        String             // "email" | "linkedin" | "search"
  status       String             // "hit" | "miss" | "error"
  responseMs   Int?
  creditCost   Float?
  rawResponse  Json?
  createdAt    DateTime           @default(now())

  @@index([contactId])
}

model OutreachTemplate {
  id        String          @id @default(cuid())
  userId    String
  name      String
  channel   OutreachChannel
  subject   String?
  body      String          @db.Text
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  messages  OutreachMessage[]

  @@index([userId])
}

model OutreachMessage {
  id                  String          @id @default(cuid())
  contactId           String
  contact             EnrichedContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  applicationId       String
  application         Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  templateId          String?
  template            OutreachTemplate? @relation(fields: [templateId], references: [id])
  userId              String

  channel             OutreachChannel
  subject             String?
  body                String          @db.Text
  status              OutreachStatus  @default(draft)

  sentAt              DateTime?
  repliedAt           DateTime?
  phantomBusterJobId  String?
  linkedinThreadId    String?
  errorMessage        String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([contactId])
  @@index([applicationId])
  @@index([userId])
}

// ─── Agent ────────────────────────────────────────────────────────────────────

enum AgentRunStatus {
  running
  completed
  failed
  pending_approval
}

model AgentConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  enabled         Boolean  @default(true)
  /// JSON array of title keywords to target, e.g. ["CEO","CTO","VP Engineering"]
  targetTitles    String[]
  maxContacts     Int      @default(3)
  /// If true, emails are sent automatically. If false, drafts queue for user approval.
  autoSend        Boolean  @default(false)
  /// Which outreach template to use by default (built-in id or custom id)
  preferredTemplate String? @default("executive-intro")
  /// Outreach channel preference
  channel         OutreachChannel @default(email)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AgentRun {
  id              String         @id @default(cuid())
  userId          String
  applicationId   String
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status          AgentRunStatus @default(running)
  triggerType     String         @default("manual") // "email_webhook" | "manual"
  triggerEmailId  String?
  contactsFound   Int            @default(0)
  contactsEnriched Int           @default(0)
  emailsDrafted   Int            @default(0)
  emailsSent      Int            @default(0)
  error           String?        @db.Text
  steps           AgentRunStep[]
  startedAt       DateTime       @default(now())
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, createdAt])
  @@index([applicationId])
  @@index([status])
}

model AgentRunStep {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  /// "search" | "enrich" | "draft" | "send" | "skip"
  kind      String
  /// "running" | "done" | "error" | "skipped"
  status    String
  summary   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([runId])
}
